{
  "name": "dmcraft-smtp-worker",
  "version": "1.0.0",
  "description": "Persistent SMTP worker for DMCraft - processes email_drafts queue with attachments",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "express": "^4.21.0",
    "nodemailer": "^6.9.15",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.0",
    "@types/nodemailer": "^6.4.16",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
